# Porta do servidor local
PORT=3000

# Token que VOCÊ cria para a Meta verificar o webhook (Ex: renove_sdr_senha_forte)
META_VERIFY_TOKEN=renove_sdr_token_123

# Token gerado no Meta for Developers para conseguir enviar mensagens de volta
META_PAGE_ACCESS_TOKEN=cole_seu_token_aqui_depois_de_gerar_na_meta